<div>IsOpen:&nbsp;@_isOpen</div>
<IonButton id="target" @onclick="@ShowPopover">Click Me</IonButton>

<IonPopover @ref="_popover" @bind-IsOpen="@_isOpen" DidDismiss="@PopoverDidDismiss" Trigger="target" Reference="@IonPopoverReference.Undefined" TriggerAction="@IonPopoverTriggerAction.Undefined" >
    <IonContent class="ion-padding">Hello World!</IonContent>
</IonPopover>

@code
{
    private IonPopover _popover = null!;
    private bool? _isOpen = false;

    private void ShowPopover() => _ = _popover.SetIsOpen(true);

    private void PopoverDidDismiss() => _ = _popover.SetIsOpen(false);
}