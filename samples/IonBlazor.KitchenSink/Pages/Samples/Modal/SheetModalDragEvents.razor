<IonHeader>
    <IonToolbar>
        <IonTitle>App</IonTitle>
    </IonToolbar>
</IonHeader>
<IonContent class="ion-padding">
    <IonButton id="open-drag-events-modal" Expand="block">Open Sheet Modal</IonButton>
    <p>
        *** This demo is hosted in a <b>&lt;ion-app&gt;</b>, the modal will <b>not</b> be bound to this preview pane!
    </p>
    <p>Drag the modal handle to fire <code>ionDragStart</code>, <code>ionDragMove</code>, and <code>ionDragEnd</code>.</p>

    <IonModal Trigger="open-drag-events-modal"
              Handle="@true"
              Breakpoints="@([0, 0.25, 0.5, 0.75, 1])"
              InitialBreakpoint="@(0.25d)"
              IonDragStart="OnDragStart"
              IonDragMove="OnDragMove"
              IonDragEnd="OnDragEnd">
        <IonContent class="ion-padding">
            <h2>Drag this sheet</h2>
            <p>Open the parent page console pane to watch every move event, or rely on the summary text on the host page.</p>
        </IonContent>
    </IonModal>
</IonContent>

@code {
    //private string _log = "(no drag events yet)";
    decimal _currentSnap = 0.25m;

    [CascadingParameter(Name = nameof(Console))]
    private PlaygroundConsole? Console { get; init; }

    private Task OnDragStart(IonModalDragStartEventArgs args)
    {
        //_log = "ionDragStart fired";
        StateHasChanged();
        return Task.CompletedTask;
    }

    private Task OnDragMove(IonModalDragMoveEventArgs args)
    {

        if (_currentSnap != args.SnapBreakpoint.GetValueOrDefault(0m))
        {
            _currentSnap = args.SnapBreakpoint.GetValueOrDefault(0m);
            Console?.Add($"Current snap breakpoint: {args.SnapBreakpoint}");
        }

        //_log =
        //    $"ionDragMove — currentY={args.CurrentY:0.##}, deltaY={args.DeltaY:0.##}, " +
        //    $"velocityY={args.VelocityY:0.##}, progress={args.Progress:0.##}, snapBreakpoint={args.SnapBreakpoint?.ToString("0.##") ?? "(card)"}";
        StateHasChanged();
        return Task.CompletedTask;
    }

    private Task OnDragEnd(IonModalDragEndEventArgs args)
    {
        //_log =
        //    $"ionDragEnd — currentY={args.CurrentY:0.##}, deltaY={args.DeltaY:0.##}, " +
        //    $"velocityY={args.VelocityY:0.##}, progress={args.Progress:0.##}, snapBreakpoint={args.SnapBreakpoint?.ToString("0.##") ?? "(card)"}";
        StateHasChanged();
        return Task.CompletedTask;
    }
}